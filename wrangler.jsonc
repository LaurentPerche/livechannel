{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "driftyt",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-30",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*", "/auth/*"]
  },
  "kv_namespaces": [
    {
      "binding": "USERS_KV",
      "id": "bf1607a3a78947c083de787ae04a2c57"
    },
    {
      "binding": "VIDEOS_KV",
      "id": "4fa673fa6673463b84f3507d47749335"
    },
    {
      "binding": "PUSH_KV",
      "id": "25f8aca597e6472d9cc629fc8a08ceba"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "USER_SCHEDULER",
        "class_name": "UserScheduler"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["UserScheduler"]
    }
  ],
  "triggers": {
    "crons": ["*/5 * * * *"]
  },
  "vars": {
    "ENVIRONMENT": "development"
  }
}
